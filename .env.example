# Local dev: run `pnpm -F db db` (turso dev) and point at it — no auth token needed.
# Production: the Turso cloud URL + token.
TURSO_DATABASE_URL="http://127.0.0.1:8080"
TURSO_AUTH_TOKEN=""

# Any random string; signs better-auth sessions.
BETTER_AUTH_SECRET=""

# Origin of the Supabase project hosting the cover videos/images. Read by
# apps/web/next.config.js to build images.remotePatterns — without it next/image
# rejects every remote cover. Keep it listed in turbo.json globalEnv too, or
# turbo's strict env mode strips it from the build.
NEXT_PUBLIC_SUPABASE_URL=""
