# Local dev: run `pnpm -F db db` (turso dev) and point at it — no auth token needed.
# Production: the Turso cloud URL + token.
TURSO_DATABASE_URL="http://127.0.0.1:8080"
TURSO_AUTH_TOKEN=""

# Any random string; signs better-auth sessions.
BETTER_AUTH_SECRET=""

# Origin of the Supabase project hosting the covers. The value below is the real
# one — it is already public in every content/*/meta.json. Read by
# apps/web/next.config.js to build images.remotePatterns, so it is load-bearing the
# moment a meta.json uses coverType: "image"; today every cover is a video and
# bypasses next/image. Keep it listed in turbo.json globalEnv too, or turbo's strict
# env mode strips it from the build and remotePatterns silently comes out empty.
NEXT_PUBLIC_SUPABASE_URL="https://zmdrwswxugswzmcokvff.supabase.co"
