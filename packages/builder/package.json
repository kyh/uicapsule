{
  "name": "@repo/builder",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm with-env tsx src/index.ts",
    "dev": "pnpm with-env tsx src/index.ts --watch",
    "clean": "git clean -xdf .cache .turbo node_modules",
    "push:remote": "dotenv -e ../../.env.production.local -- tsx src/index.ts",
    "with-env": "dotenv -e ../../.env --"
  },
  "dependencies": {
    "@repo/api": "workspace:*",
    "@repo/db": "workspace:*",
    "chokidar": "^5.0.0"
  },
  "devDependencies": {
    "@kyh/tsconfig": "catalog:",
    "tsx": "^4.21.0",
    "typescript": "catalog:"
  }
}
